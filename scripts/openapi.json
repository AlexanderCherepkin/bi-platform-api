  "components": {
    "schemas": {
      "Body_login_auth_token_post": {
        "properties": {
          "grant_type": {
            "anyOf": [
              {
                "type": "string",
                "pattern": "password"
              },
              {
                "type": "null"
              }
            ],
            "title": "Grant Type"
          },
          "username": {
            "type": "string",
            "title": "Username"
          },
          "password": {
            "type": "string",
            "title": "Password"
          },
          "scope": {
            "type": "string",
            "title": "Scope",
            "default": ""
          },
          "client_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Client Id"
          },
          "client_secret": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Client Secret"
          }
        },
        "type": "object",
        "required": [
          "username",
          "password"
        ],
        "title": "Body_login_auth_token_post"
      },
      "Body_run_query_db_query_post": {
        "properties": {
          "sql": {
            "type": "string",
            "title": "Sql"
          }
        },
        "type": "object",
        "required": [
          "sql"
        ],
        "title": "Body_run_query_db_query_post"
      },
      "DataInputOut": {
        "properties": {
          "entry_id": {
            "type": "integer",
            "title": "Entry Id"
          },
          "template_id": {
            "type": "integer",
            "title": "Template Id"
          },
          "submitted_by": {
            "type": "string",
            "title": "Submitted By"
          },
          "submitted_at": {
            "type": "string",
            "format": "date-time",
            "title": "Submitted At"
          },
          "entry_data": {
            "type": "object",
            "title": "Entry Data"
          },
          "status": {
            "type": "string",
            "title": "Status"
          },
          "applied_at": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "Applied At"
          }
        },
        "type": "object",
        "required": [
          "entry_id",
          "template_id",
          "submitted_by",
          "submitted_at",
          "entry_data",
          "status"
        ],
        "title": "DataInputOut"
      },
      "DataInputSubmit": {
        "properties": {
          "template_code": {
            "type": "string",
            "title": "Template Code"
          },
          "entry_data": {
            "type": "object",
            "title": "Entry Data"
          }
        },
        "type": "object",
        "required": [
          "template_code",
          "entry_data"
        ],
        "title": "DataInputSubmit"
      },
      "ExpenseCreate": {
        "properties": {
          "expense_date": {
            "type": "string",
            "format": "date",
            "title": "Expense Date"
          },
          "account_id": {
            "type": "integer",
            "title": "Account Id"
          },
          "department_id": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Department Id"
          },
          "employee_id": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Employee Id"
          },
          "expense_category": {
            "type": "string",
            "maxLength": 100,
            "minLength": 1,
            "title": "Expense Category"
          },
          "expense_item": {
            "type": "string",
            "maxLength": 255,
            "minLength": 1,
            "title": "Expense Item"
          },
          "currency_id": {
            "type": "integer",
            "title": "Currency Id"
          },
          "amount_original": {
            "anyOf": [
              {
                "type": "number",
                "exclusiveMinimum": 0.0
              },
              {
                "type": "string"
              }
            ],

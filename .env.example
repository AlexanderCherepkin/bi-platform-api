ETL_AMOCRM_BASE_URL=https://example.amocrm.ru
ETL_AMOCRM_ACCESS_TOKEN=
ETL_AMOCRM_DEMO=true

# ETL Google Sheets (заполнить после настройки Google Cloud Console)

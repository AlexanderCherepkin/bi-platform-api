# Metabase (порт 3001, чтобы не конфликтовать с Next.js на 3000)
METABASE_URL=http://localhost:3001
METABASE_ADMIN_EMAIL=admin@company.local
METABASE_ADMIN_PASSWORD=CorpB1_Pass2024!

# ETL: общие настройки
ETL_RUN_INTERVAL_MINUTES=60
METRICS_CACHE_TTL_SECONDS=300

# ETL 1С (заполнить после согласования с 1С-программистом)
